{
  "actions": [
    {
      "action": "open",
      "argument": {
        "url": "https://news.ycombinator.com",
        "waitUntil": "load"
      }
    },
    {
      "action": "evaluate",
      "argument": {
        "script": "async (intermediate) => { const res = await fetch('https://hacker-news.firebaseio.com/v0/user/{{ username }}.json'); const data = await res.json(); if (!data) return []; return [{ username: data.id, karma: data.karma, created: data.created ? new Date(data.created * 1000).toISOString().slice(0, 10) : '', about: data.about || '' }]; }"
      }
    }
  ],
  "api_endpoint": "hackernews-user",
  "category": "scrape",
  "description": "Hacker News user profile",
  "is_public": true,
  "method": "GET",
  "name": "User",
  "output_schema": [
    {
      "name": "username",
      "type": "string",
      "description": "用户名"
    },
    {
      "name": "karma",
      "type": "number",
      "description": "积分"
    },
    {
      "name": "created",
      "type": "string",
      "description": "创建时间"
    },
    {
      "name": "about",
      "type": "string",
      "description": "简介"
    }
  ],
  "variables": [
    {
      "name": "username",
      "type": "string",
      "required": true,
      "help": "HN username"
    }
  ],
  "website_domain": "news.ycombinator.com",
  "website_id": "website-news.ycombinator.com"
}
