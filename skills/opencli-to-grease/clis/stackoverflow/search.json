{
  "actions": [
    {
      "action": "open",
      "argument": {
        "url": "https://stackoverflow.com",
        "waitUntil": "load"
      }
    },
    {
      "action": "evaluate",
      "argument": {
        "script": "async (intermediate) => { const res = await fetch('https://api.stackexchange.com/2.3/search/advanced?order=desc&sort=relevance&q={{ query }}&site=stackoverflow'); const data = await res.json(); return (data?.items || []).slice(0, {{ limit }}).map((item, i) => ({ rank: i + 1, title: item.title, score: item.score, answers: item.answer_count, url: item.link })); }"
      }
    }
  ],
  "api_endpoint": "stackoverflow-search",
  "category": "search",
  "description": "Search Stack Overflow questions",
  "is_public": true,
  "method": "GET",
  "name": "Search",
  "output_schema": [
    {
      "name": "rank",
      "type": "number",
      "description": "排名"
    },
    {
      "name": "title",
      "type": "string",
      "description": "标题"
    },
    {
      "name": "score",
      "type": "number",
      "description": "得分"
    },
    {
      "name": "answers",
      "type": "number",
      "description": "回答数"
    },
    {
      "name": "url",
      "type": "string",
      "description": "链接"
    }
  ],
  "variables": [
    {
      "name": "query",
      "type": "string",
      "required": true,
      "help": "Search query"
    },
    {
      "name": "limit",
      "type": "int",
      "default": 10,
      "help": "Max number of results"
    }
  ],
  "website_domain": "stackoverflow.com",
  "website_id": "website-stackoverflow.com"
}