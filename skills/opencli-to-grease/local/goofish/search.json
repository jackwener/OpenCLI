{
  "actions": [
    {
      "action": "open",
      "argument": {
        "url": "https://www.goofish.com/search",
        "waitUntil": "networkidle"
      }
    },
    {
      "action": "waitTarget",
      "argument": {
        "condition": "appear",
        "target": "the search input field"
      }
    },
    {
      "action": "input",
      "argument": {
        "delay": 20,
        "target": "the search input field",
        "text": "{{ querystring }}",
        "withReturn": true
      }
    },
    {
      "action": "evaluate",
      "argument": {
        "script": "async (intermediate) => { const maxWait = 5000; const startTime = Date.now(); while (Date.now() - startTime < maxWait) { if (!document.body) { await new Promise(r => setTimeout(r, 100)); continue; } const loadingText = document.body.innerText.includes('加载中...'); if (!loadingText) break; await new Promise(r => setTimeout(r, 500)); } return { waited: Date.now() - startTime }; }"
      }
    },
    {
      "action": "extractList",
      "argument": {
        "contentType": "link",
        "ignoreErrors": false,
        "target": "all search results"
      }
    }
  ],
  "api_endpoint": "search-wb7yqg",
  "category": "search",
  "description": "Search",
  "is_public": true,
  "method": "POST",
  "name": "Search",
  "variables": [
    {
      "name": "querystring",
      "type": "string",
      "required": true,
      "help": "搜索关键词",
      "test": "iphone"
    }
  ],
  "output_schema": [
    {
      "name": "links",
      "type": "string",
      "description": "搜索结果列表"
    }
  ],
  "website_domain": "www.goofish.com",
  "website_id": "website-www.goofish.com"
}